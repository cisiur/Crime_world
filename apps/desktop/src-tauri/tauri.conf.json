{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrimeWorld",
  "version": "0.1.0",
  "identifier": "com.crimeworld.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CrimeWorld",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 520
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all"
  }
}
